docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent conflicts.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a multi-platform environment, the lock file may not be portable.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but may not be needed in all contexts.
#poetry.lock

# pdm
.pdm-plugins/
.pdm-python/

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

